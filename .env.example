# Code Review Agent — environment variable reference
# Copy this file to .env in your target project and fill in real values.
# NEVER commit .env with real secrets.

# AI Provider API keys (set ONE of these — priority: Groq > Gemini > OpenAI > Claude)
GROQ_API_KEY=your_groq_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: URL of a centralised rule API
REVIEW_RULES_API_URL=https://rules.yourcompany.com/api/v1

# Optional: Bearer token for authenticating with the rules API
REVIEW_RULES_API_TOKEN=your_token_here

# Optional: Power Automate webhook URL for daily report delivery
# CRA_FLOW_URL=https://your-flow-url-here
